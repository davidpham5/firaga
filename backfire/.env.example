# Database — matches docker-compose.yml defaults
DATABASE_URI=postgresql://firaga:firaga@localhost:5432/firaga

# Payload secret — change this to a long random string in production
PAYLOAD_SECRET=change-me-to-a-long-random-string

# Public URL of this backend service
NEXT_PUBLIC_SERVER_URL=http://localhost:3001

# Email — points to maildev in dev, swap for Resend in production
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM_ADDRESS=hello@firaga.io
SMTP_FROM_NAME=Firaga

# Cloudflare R2 / S3-compatible storage (optional in dev — uses local disk if unset)
# S3_BUCKET=
# S3_REGION=auto
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
